# ── Database ─────────────────────────────────────────────────────────────────
# Create a separate DB for Wondish02 (don't share with the legacy FastAPI DB)
DATABASE_URL="postgresql://user:password@host:5432/wondish02"

# ── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 64
NEXTAUTH_SECRET="your-nextauth-secret"

# ── JWT (internal) ───────────────────────────────────────────────────────────
JWT_SECRET="your-jwt-secret"
JWT_REFRESH_SECRET="your-jwt-refresh-secret"
JWT_EXPIRATION="5m"

# ── Legacy FastAPI backend (optional — for proxying to existing API) ──────────
NEXT_PUBLIC_WONDISH_PLANNER_URL="http://localhost:80"

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PREMIUM_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── Email (Nodemailer / Gmail SMTP) ──────────────────────────────────────────
EMAIL_FROM="no-reply@wondish.io"
EMAIL_USER="your-gmail@gmail.com"
# Use a Gmail App Password (not your account password)
EMAIL_PASS="xxxx xxxx xxxx xxxx"

# ── AWS S3 (image uploads) ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION="us-east-1"
AWS_S3_BUCKET="your-bucket-name"

# ── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
VERIFICATION_URL="http://localhost:3000/verify-email?token="
RESET_PASSWORD_URL="http://localhost:3000/reset-password?token="
